# =========================================================
# Portfolio Platform - Git Ignore
# =========================================================

# ---------------------------------------------------------
# Operating System Files
# ---------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ---------------------------------------------------------
# Environment Variables
# ---------------------------------------------------------
.env
.env.*
!.env.example

# Local Spring Boot secrets (never commit real credentials)
application-local.properties

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------
# Java / Spring Boot
# ---------------------------------------------------------
target/
*.class
*.jar
*.war
*.ear

# Maven Wrapper (keep these)
!.mvn/wrapper/maven-wrapper.jar

# ---------------------------------------------------------
# IntelliJ IDEA
# ---------------------------------------------------------
.idea/
*.iml

# ---------------------------------------------------------
# Eclipse
# ---------------------------------------------------------
.settings/
.project
.classpath

# ---------------------------------------------------------
# VS Code
# ---------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# ---------------------------------------------------------
# Node / React / Vite
# ---------------------------------------------------------
node_modules/
dist/
build/
coverage/

# npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------
# Temporary Files
# ---------------------------------------------------------
*.tmp
*.temp
*.swp
*.swo

# ---------------------------------------------------------
# Cache
# ---------------------------------------------------------
.cache/
.parcel-cache/

# ---------------------------------------------------------
# MacOS
# ---------------------------------------------------------
.AppleDouble
.LSOverride

# ---------------------------------------------------------
# Windows
# ---------------------------------------------------------
ehthumbs.db
Icon?

# ---------------------------------------------------------
# Database
# ---------------------------------------------------------
*.db

# ---------------------------------------------------------
# Generated Files
# ---------------------------------------------------------
out/
bin/